{%- comment -%}
  Image Comparison Section
  Auto-hides if on product page and no comparison images metafield exists
{%- endcomment -%}

{%- liquid
  assign show_section = true
  assign comparison_block = section.blocks | where: 'type', 'comparison' | first
  assign meta_results = null

  # Prioridad:
  # 1. Bloque (con posible conexión dinámica a metafield del producto)
  # 2. Metafield del producto (fallback automático)
  # 3. Settings de la sección (fallback manual)

  if comparison_block != blank
    assign meta_results = comparison_block.settings.metaobject_data
  endif

  if meta_results == blank
    assign meta_results = product.metafields.custom.resultados_comparacion.value
  endif

  if product != blank
    if meta_results == blank and comparison_block == blank
      if section.settings.image_1 == blank and section.settings.image_2 == blank
        assign show_section = false
      endif
    endif
  endif
-%}

{%- if show_section -%}
  {{ 'component-image-comparison.css' | asset_url | stylesheet_tag }}

  {%- liquid
    assign mg_top_desktop = section.settings.mg_top_desktop | append: 'px'
    assign mg_top_tablet = section.settings.mg_top_tablet | append: 'px'
    assign mg_top_mobile = section.settings.mg_top_mobile | append: 'px'

    assign mg_bottom_desktop = section.settings.mg_bottom_desktop | append: 'px'
    assign mg_bottom_tablet = section.settings.mg_bottom_tablet | append: 'px'
    assign mg_bottom_mobile = section.settings.mg_bottom_mobile | append: 'px'

    assign container = section.settings.container | replace: 'fullwidth', 'full'
    if container == 'container'
      assign container = 'container'
    else
      assign container = 'container-' | append: container
    endif
    assign padding_full_width = section.settings.padding_full_width | append: 'px'

    assign section_subtitle_font_size = section.settings.section_subtitle_font_size | append: 'px'
    assign section_subtitle_font_size_mb = section.settings.section_subtitle_font_size_mb | append: 'px'
    assign section_subtitle_color = section.settings.section_subtitle_color
    assign section_subtitle_font_weight = section.settings.section_subtitle_font_weight
    assign section_subtitle_margin_top = section.settings.section_subtitle_margin_top | append: 'px'
    assign section_subtitle_font_style = section.settings.section_subtitle_font_style
    assign section_subtitle_letter_spacing = section.settings.section_subtitle_letter_spacing

    assign section_bg = section.settings.section_bg
    assign section_gradient = section.settings.section_gradient

    assign block_titulo = null
    assign block_subtitulo = null
    assign block_descripcion = null
    assign block_imagen_antes = null
    assign block_imagen_despues = null
    assign block_etiqueta_antes = null
    assign block_etiqueta_despues = null

    if comparison_block != blank
      assign block_titulo = comparison_block.settings.titulo
      assign block_subtitulo = comparison_block.settings.subtitulo
      assign block_descripcion = comparison_block.settings.descripcion
      assign block_imagen_antes = comparison_block.settings.imagen_antes
      assign block_imagen_despues = comparison_block.settings.imagen_despues
      assign block_etiqueta_antes = comparison_block.settings.etiqueta_antes
      assign block_etiqueta_despues = comparison_block.settings.etiqueta_despues
    endif

    assign section_title = block_titulo | default: meta_results.titulo
    assign section_title_font_size = section.settings.section_title_font_size | append: 'px'
    assign section_title_font_size_mb = section.settings.section_title_font_size_mb | append: 'px'
    assign section_title_color = section.settings.section_title_color
    assign section_title_font_weight = section.settings.section_title_font_weight
    assign section_title_margin_top = section.settings.section_title_margin_top | append: 'px'
    assign section_title_font_style = section.settings.section_title_font_style
    assign section_title_max_width = section.settings.section_title_max_width | append: 'px'
    assign section_title_letter_spacing = section.settings.section_title_letter_spacing

    assign image_before = block_imagen_antes | default: meta_results.imagen_antes | default: section.settings.image_1
    assign image_after = block_imagen_despues | default: meta_results.imagen_despues | default: section.settings.image_2

    assign label_before = block_etiqueta_antes | default: meta_results.etiqueta_antes
    assign label_after = block_etiqueta_despues | default: meta_results.etiqueta_despues

    assign section_description = block_descripcion | default: meta_results.subtitulo
    assign section_description_font_size = section.settings.section_description_font_size | append: 'px'
    assign section_description_font_size_mb = section.settings.section_description_font_size_mb | append: 'px'
    assign section_description_font_weight = section.settings.section_description_font_weight
    assign section_description_color = section.settings.section_description_color
    assign section_description_margin_top = section.settings.section_description_margin_top | append: 'px'
    assign section_description_max_width = section.settings.section_description_max_width | append: 'px'
    assign section_description_letter_spacing = section.settings.section_description_letter_spacing

    assign image_before_mobile = section.settings.image_1_mobile
    assign image_after_mobile = section.settings.image_2_mobile

    if image_before_mobile != blank and image_after_mobile != blank
      assign show_image_mobile = true
    endif

    assign section_subtitle = block_subtitulo
  -%}

  <style>
    @media (min-width: 1200px) {
        .section-block-{{section.id}} {
            padding-top: {{ mg_top_desktop }};
            padding-bottom: {{ mg_bottom_desktop }};
        }
    }

    {% if section.settings.container == 'fullwidth' %}
        @media (min-width: 1025px) {
            .section-block-{{section.id}} .container-full {
                padding-left: {{ padding_full_width }};
                padding-right: {{ padding_full_width }};
            }
        }
    {% endif %}

    @media (min-width: 768px) and (max-width: 1199px) {
        .section-block-{{ section.id }} {
            padding-top: {{ mg_top_tablet }};
            padding-bottom: {{ mg_bottom_tablet }};
        }
    }

    @media (max-width: 767px) {
        .section-block-{{ section.id }} {
            padding-top: {{ mg_top_mobile }};
            padding-bottom: {{ mg_bottom_mobile }};
        }
    }
    .comparison-label {
        position: absolute;
        bottom: 20px;
        background: rgba(255, 255, 255, 0.8);
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        z-index: 5;
        color: #000;
        pointer-events: none;
    }
    .label-antes { left: 20px; }
    .label-despues { right: 20px; }

    .content-position-top {
        flex-direction: column;
    }

    .content-position-top .section-images {
        width: 100% !important;
    }

    .content-position-top .images-container {
        margin: 0 auto;
    }

    .compare-image img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .adaptive_height {
        position: relative;
        width: 100%;
        overflow: hidden;
    }

    /* Reduce image size on desktop */
    @media (min-width: 1024px) {
        .section-block-{{section.id}} .images-container {
            {% unless section.settings.container == 'fullwidth' %}
            max-width: 800px;
            {% endunless %}
            margin-left: auto;
            margin-right: auto;
        }
    }
  </style>

  <div
    class="image-comparison section-block-{{ section.id }} {% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--slide-in{% endif %}"
    id="image-comparison-{{ section.id }}"
    style="--section-bg: {% if section_gradient != blank %}{{ section_gradient }}{% elsif section_bg != blank %}{{ section_bg }}{% endif %};"
  >
    <div class="{{ container }}">
      <!-- Title and Description centered above image -->
      {% if section_subtitle != blank or section_title != blank or section_description != blank %}
        <div class="section-text-centered" style="text-align: center; margin-bottom: 2rem;">
          {% if section_subtitle != blank %}
            <h4
              class="subtitle {% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--fade-in{% endif %}"
              style="
                {% if settings.banner_animation == 'effect_fade_up' %}--animation-order: 0;{% endif %}
                --subtitle-font-size: {{ section_subtitle_font_size }};
                --subtitle-font-size-mb: {{ section_subtitle_font_size_mb }};
                --subtitle-font-weight: {{ section_subtitle_font_weight }};
                --subtitle-color: {% if section_subtitle_color != blank %}{{ section_subtitle_color }}{% endif %};
                --subtitle-margin-top: {{ section_subtitle_margin_top }};
                --subtitle-font-style: {{ section_subtitle_font_style }};
                --subtitle-letter-spacing: {{ section_subtitle_letter_spacing }};
              "
            >
              {{ section_subtitle }}
            </h4>
          {% endif %}
          {% if section_title != blank %}
            <h3
              class="title {% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--fade-in{% endif %}"
              style="
                {% if settings.banner_animation == 'effect_fade_up' %}--animation-order: 1;{% endif %}
                --title-font-size: {{ section_title_font_size }};
                --title-font-size-mb: {{ section_title_font_size_mb }};
                --title-font-weight: {{ section_title_font_weight }};
                --title-color: {% if section_title_color != blank %}{{ section_title_color }}{% endif %};
                --title-margin-top: {{ section_title_margin_top }};
                --title-font-style: {{ section_title_font_style }};
                --title-max-width: {{ section_title_max_width }};
                --title-letter-spacing: {{ section_title_letter_spacing }};
                margin-left: auto;
                margin-right: auto;
              "
            >
              <span class="text">
                {{ section_title }}
              </span>
            </h3>
          {% endif %}
          {% if section_description != blank %}
            <div
              class="description {% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--fade-in{% endif %}"
              style="
                {% if settings.banner_animation == 'effect_fade_up' %}--animation-order: 2;{% endif %}
                --description-font-size: {{ section_description_font_size }};
                --description-font-size-mb: {{ section_description_font_size_mb }};
                --description-color: {% if section_description_color != blank %}{{ section_description_color }}{% endif %};
                --description-font-weight: {{ section_description_font_weight }};
                --description-margin-top: {{ section_description_margin_top }};
                --description-max-width: {{ section_description_max_width }};
                --description-letter-spacing: {{ section_description_letter_spacing }};
                margin-left: auto;
                margin-right: auto;
              "
            >
              {{ section_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <!-- Comparison Image -->
      <div class="section-content content-position-{{ section.settings.content_position }}">
        <image-comparison-component class="section-images">
          <div
            class="images-container {% if settings.banner_animation == 'effect_fade_up' %} scroll-trigger animate--fade-in{% endif %}"
            data-images-container
            style="--left-pos: 50%"
          >
            <!-- After Image (Base) -->
            {% if image_after != blank %}
              <div
                class="adaptive_height compare-image{% unless show_image_mobile %} not-image-mobile{% endunless %}"
                data-image-overlay
                style="padding-top: {{ 1 | divided_by: image_after.aspect_ratio | times: 100 }}%"
              >
                <img
                  width="{{ image_after.width }}"
                  height="{{ image_after.height }}"
                  {% render 'lazyload', preview_img: image_after %}
                  {% unless image_after.presentation.focal_point == '50.0% 50.0%' %}
                    style="object-position: {{ image_after.presentation.focal_point }}"
                  {% endunless %}
                >
                {% if label_after != blank %}
                  <span class="comparison-label label-despues">{{ label_after }}</span>
                {% endif %}
                {% if settings.enable_lazyload %}<span class="data-lazy-loading"></span>{% endif %}
              </div>
            {% else %}
              <div
                class="adaptive_height placeholder compare-image"
                style="--height_placeholder: 750px;"
                data-image-overlay
              >
                {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}

            <!-- Slider Handle -->
            <div class="image-comparison-slider" data-image-slider>
              <span class="slider-divider"></span>
              <div class="slider-thumb">
                <div class="slider-thumb-arrows">
                  {% render 'icon-caret-right' %}
                  {% render 'icon-caret-right' %}
                </div>
              </div>
            </div>

            <!-- Before Image (Overlay - Left) -->
            {% if image_before != blank %}
              <div
                class="adaptive_height compare-image compare-image-overlay{% unless show_image_mobile %} not-image-mobile{% endunless %}"
                style="padding-top: {{ 1 | divided_by: image_before.aspect_ratio | times: 100 }}%"
              >
                <img
                  width="{{ image_before.width }}"
                  height="{{ image_before.height }}"
                  {% render 'lazyload', preview_img: image_before %}
                  {% unless image_before.presentation.focal_point == '50.0% 50.0%' %}
                    style="object-position: {{ image_before.presentation.focal_point }}"
                  {% endunless %}
                >
                {% if label_before != blank %}
                  <span class="comparison-label label-antes">{{ label_before }}</span>
                {% endif %}
                {% if settings.enable_lazyload %}<span class="data-lazy-loading"></span>{% endif %}
              </div>
            {% else %}
              <div
                class="adaptive_height compare-image-overlay placeholder compare-image"
                style="--height_placeholder: 750px;"
              >
                {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}

            <!-- Mobile Support -->
            {% if show_image_mobile %}
              <!-- After Mobile (Base) -->
              <div
                class="adaptive_height compare-image mobile"
                data-image-overlay
                style="padding-top: {{ 1 | divided_by: image_after_mobile.aspect_ratio | times: 100 }}%"
              >
                <img
                  width="{{ image_after_mobile.width }}"
                  height="{{ image_after_mobile.height }}"
                  {% render 'lazyload', preview_img: image_after_mobile %}
                >
                {% if label_after != blank %}
                  <span class="comparison-label label-despues">{{ label_after }}</span>
                {% endif %}
              </div>
              <!-- Before Mobile (Overlay) -->
              <div
                class="adaptive_height compare-image compare-image-overlay mobile"
                style="padding-top: {{ 1 | divided_by: image_before_mobile.aspect_ratio | times: 100 }}%"
              >
                <img
                  width="{{ image_before_mobile.width }}"
                  height="{{ image_before_mobile.height }}"
                  {% render 'lazyload', preview_img: image_before_mobile %}
                >
                {% if label_before != blank %}
                  <span class="comparison-label label-antes">{{ label_before }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </image-comparison-component>
      </div>
    </div>
  </div>

  <script>
    if (typeof ImageComparisonComponent == 'undefined') {
      class ImageComparisonComponent extends HTMLElement {
        constructor() {
          super();

          this.initLoad();
          this.initComparisons();
        }

        initLoad() {
          const handler = (entries, observer) => {
            if (entries[0].isIntersecting) {
              const imagesContainer = this.querySelector('[data-images-container]');
              imagesContainer.style.setProperty('--left-pos', '50%');
              imagesContainer.querySelector('.slider-thumb-arrows').style.transform = 'rotate(0deg)';

              setTimeout(() => imagesContainer.classList.add('loaded'), 1000);

              observer.unobserve(this);
            }
          };

          const options = {
            threshold: 0.7,
          };

          this.observer = new IntersectionObserver(handler, options);
          this.observer.observe(this);
        }

        initComparisons() {
          this.clicked = false;
          this.container = this.querySelector('[data-images-container]');
          this.slider = this.querySelector('[data-image-slider]');
          this.imageOverlay = this.querySelector('[data-image-overlay]');
          this.compareImages();
        }

        compareImages() {
          this.width = this.imageOverlay.offsetWidth;
          this.height = this.imageOverlay.offsetHeight;

          this.slider.addEventListener('mousedown', this.slideReady.bind(this));
          this.slider.addEventListener('touchstart', this.slideReady.bind(this));
          window.addEventListener('mouseup', this.slideFinish.bind(this));
          window.addEventListener('touchend', this.slideFinish.bind(this));
        }

        slideReady(e) {
          e.preventDefault();
          this.clicked = true;

          window.addEventListener('mousemove', this.slideMove.bind(this));
          window.addEventListener('touchmove', this.slideMove.bind(this));
        }

        slideMove(e) {
          if (!this.clicked) return false;

          const currentLeftPercent = this.getCursorLeft(e);
          this.container.style.setProperty('--left-pos', `${currentLeftPercent}%`);
        }

        slideFinish(e) {
          this.clicked = false;
        }

        getCursorLeft(e) {
          const event = e.changedTouches ? e.changedTouches[0] : e;
          const { left, width } = this.container.getBoundingClientRect();
          const sliderButtonWidthPercent = ((this.slider.getBoundingClientRect().width + 4) * 100) / width;
          const min = sliderButtonWidthPercent / 2;
          const max = 100 - min;

          const delta = event.pageX - left;
          let percent = (delta / width) * 100;

          if (percent < min) percent = min;
          if (percent > max) percent = max;

          return percent;
        }
      }

      window.addEventListener('load', () =>
        customElements.define('image-comparison-component', ImageComparisonComponent)
      );
    }
  </script>
{%- endif -%}
