<section class="comp-v3-section comp-v2-id-{{ section.id }} comp-v3-id-{{ section.id }}">
  <div class="comp-v3-container">
    <div class="comp-v3-header">
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="comp-v3-slider-wrap">
      {%- if section.blocks.size > 1 -%}
        <button class="comp-v3-nav-btn comp-v3-prev prev-{{ section.id }}" aria-label="Anterior">
          <svg viewBox="0 0 14 10" fill="none" class="icon icon-prev" style="transform: scaleX(-1);">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path>
          </svg>
        </button>
        <button class="comp-v3-nav-btn comp-v3-next next-{{ section.id }}" aria-label="Siguiente">
          <svg viewBox="0 0 14 10" fill="none" class="icon icon-next">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path>
          </svg>
        </button>
      {%- endif -%}

      <div class="comp-v3-slider-view">
        <div class="comp-v3-track track-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- liquid
              assign product_ours = block.settings.product_ours
              assign product_img = block.settings.product_img | default: product_ours.featured_image
              assign product_name = block.settings.product_name | default: product_ours.title | default: 'Levnicare'
              assign comp_name = block.settings.comp_name | default: 'Otros'
            -%}
            <div class="comp-v3-slide" {{ block.shopify_attributes }}>
              <div class="comp-v3-wave">
                <svg viewBox="0 0 1000 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                  <!-- Wave 1 (Back) -->
                  <path d="M1000,300 C850,150 700,80 500,180 C300,280 150,150 0,300 L0,300 L1000,300 Z" fill="{{ section.settings.wave_color_1 | default: '#e05060' }}" opacity="0.4" stroke="none" stroke-width="0"/>
                  <!-- Wave 2 (Middle) - More wavy but carefully positioned -->
                  <path d="M1000,300 C900,250 800,50 700,150 C600,250 500,100 400,200 C300,300 150,50 0,300 L0,300 L1000,300 Z" fill="{{ section.settings.wave_color_2 | default: '#e05060' }}" opacity="0.6" stroke="none" stroke-width="0"/>
                  <!-- Wave 3 (Front) -->
                  <path d="M1000,300 C800,280 600,150 400,250 C250,320 100,180 0,300 L0,300 L1000,300 Z" fill="{{ section.settings.wave_color_3 | default: '#e05060' }}" opacity="0.8" stroke="none" stroke-width="0"/>
                </svg>
              </div>

              <div class="comp-v3-card">
                <table class="comp-v3-table">
                  <colgroup>
                    <col class="col-label">
                    <col class="col-ours">
                    <col class="col-them">
                  </colgroup>
                  <thead>
                    <tr>
                      <th><!-- Spacer --></th>
                      <th class="th-ours">
                        <div class="comp-v3-badge">{{ section.settings.badge_text }}</div>
                        {%- if product_img != blank -%}
                          {{
                            product_img
                            | image_url: width: 500, height: 570, crop: 'center'
                            | image_tag: class: 'comp-v3-img-pop comp-v3-img-ours'
                          }}
                        {%- endif -%}
                        {{ product_name }}
                      </th>
                      <th class="th-them">
                        {%- if block.settings.comp_img != blank -%}
                          {{
                            block.settings.comp_img
                            | image_url: width: 500, height: 570, crop: 'center'
                            | image_tag: class: 'comp-v3-img-pop comp-v3-img-comp'
                          }}
                        {%- endif -%}
                        {{ comp_name }}
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {%- for i in (1..4) -%}
                      {%- liquid
                        assign label_key = 'feature_' | append: i | append: '_label'
                        assign ours_key = 'feature_' | append: i | append: '_ours'
                        assign theirs_key = 'feature_' | append: i | append: '_theirs'
                        assign label = block.settings[label_key]
                      -%}
                      {%- if label != blank -%}
                        <tr>
                          <td class="td-label">{{ label }}</td>
                          <td class="td-ours">
                            {%- if block.settings[ours_key] -%}
                              {{ seal_svg }}
                            {%- else -%}
                              <span class="comp-v3-x">✕</span>
                            {%- endif -%}
                          </td>
                          <td>
                            {%- if block.settings[theirs_key] -%}
                              {{ seal_svg }}
                            {%- else -%}
                              <span class="comp-v3-x">✕</span>
                            {%- endif -%}
                          </td>
                        </tr>
                      {%- endif -%}
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="comp-v3-dots dots-{{ section.id }}">
          {%- for block in section.blocks -%}
            <span class="comp-v3-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    const section = document.querySelector('.comp-v3-id-{{ section.id }}');
    const track = section.querySelector('.track-{{ section.id }}');
    const prev = section.querySelector('.prev-{{ section.id }}');
    const next = section.querySelector('.next-{{ section.id }}');
    const dots = section.querySelectorAll('.comp-v3-dot');

    if (!track) return;

    let index = 0;
    const slides = Array.from(track.children);

    const update = () => {
      index = Math.max(0, Math.min(index, slides.length - 1));
      track.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === index);
        slide.classList.toggle('is-past', i < index);
        slide.classList.toggle('is-future', i > index);
      });
    };

    update();

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('is-visible');
            observer.unobserve(section);
          }
        });
      },
      { threshold: 0.2 }
    );

    observer.observe(section);

    if (prev)
      prev.addEventListener('click', () => {
        index--;
        update();
      });
    if (next)
      next.addEventListener('click', () => {
        index++;
        update();
      });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        index = parseInt(dot.dataset.index);
        update();
      });
    });
  })();
</script>

