{%- style -%}
  .comp-v3-id-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --bg-color: {{ section.settings.bg_color }};
    --container-width: {{ section.settings.container_width }}px;
    --title-size: {{ section.settings.title_size }}px;
    --wave-color: {{ section.settings.wave_color | default: '#e05060' }};
    --title-color: {{ section.settings.title_color | default: '#000000' }};
    --subtitle-color: {{ section.settings.subtitle_color | default: '#666666' }};
    --mint-bg: {{ section.settings.col_body_bg | default: '#c8f7d8' }};
    --mint-header: {{ section.settings.col_header_bg | default: '#b8f5ca' }};
    --green-badge: {{ section.settings.col_badge_bg | default: '#25a85b' }};
    --badge-text-color: {{ section.settings.col_badge_text | default: '#ffffff' }};
    --pink-border: {{ section.settings.border_color | default: '#f0a0a8' }};
  }
{%- endstyle -%}

{{ 'component-comparison-table.css' | asset_url | stylesheet_tag }}

